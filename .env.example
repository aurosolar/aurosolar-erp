# ═══════════════════════════════════════════
# AURO SOLAR ERP — Variables de Entorno
# Copiar a .env y rellenar con valores reales
# ═══════════════════════════════════════════

# Base de datos PostgreSQL
DATABASE_URL="postgresql://aurosolar:TU_PASSWORD@localhost:5432/aurosolar_erp"

# Auth
NEXTAUTH_SECRET="generar-con-openssl-rand-base64-32"
NEXTAUTH_URL="https://app.aurosolar.es"

# Entorno
NODE_ENV="development"

# Storage (ruta base para uploads)
STORAGE_PATH="/var/data/aurosolar/uploads"

# Logs
LOG_LEVEL="info"
LOG_PATH="/var/data/aurosolar/logs"
